// GoogleCredentials.swift — LOCAL ONLY, not committed (see .gitignore)
// To build with Google Drive export support:
//   1. Copy this file to GoogleCredentials.swift (same directory)
//   2. Fill in your own OAuth 2.0 credentials (see README § Google Drive Export)
extension GoogleDriveConfig {
    static let clientID     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
    static let clientSecret = "YOUR_CLIENT_SECRET"
}
